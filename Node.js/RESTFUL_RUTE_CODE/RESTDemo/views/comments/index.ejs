<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>コメント一覧</title>
</head>
<body>
    <h1>コメント</h1>
    <ul>
        <% for(let c of comments) { %>
               <li><%= c.comment %> - <b><%= c.username %></b></li>
               <a href="/comments/<%= c.id %>">詳細</a>
        <% } %>
    </ul>
    <a href="/comments/new">新規コメント作成</a>
</body>
</html>